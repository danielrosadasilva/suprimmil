@namespace suprimmil.Components.Content.Button

@* Button.razor *@
<button type="@(IsSubmit ? "submit" : "button")" disabled="@Disabled" @onclick="OnClick" class="@ComputedClass" @attributes="AdditionalAttributes">
    @ChildContent
</button>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool IsSubmit { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }
    [Parameter] public ButtonVariant Variant { get; set; } = ButtonVariant.Default;
    [Parameter] public ButtonSize Size { get; set; } = ButtonSize.Medium;
    [Parameter] public string? Class { get; set; }

    private string BaseStyles => "inline-flex items-center justify-center rounded-md font-medium transition";

    private string VariantStyles => Variant switch
    {
        ButtonVariant.Default => "bg-zinc-900 text-white hover:bg-zinc-800",
        ButtonVariant.Secondary => "bg-zinc-100 text-zinc-900 hover:bg-zinc-200",
        ButtonVariant.Ghost => "hover:bg-zinc-100",
        ButtonVariant.Destructive => "bg-red-500 text-white hover:bg-red-600",
        ButtonVariant.Success => "bg-green-500 text-white hover:bg-green-600",
        ButtonVariant.Warning => "bg-yellow-500 text-white hover:bg-yellow-600",
        ButtonVariant.Info => "bg-blue-500 text-white hover:bg-blue-600",
        _ => ""
    };

    private string SizeStyles => Size switch
    {
        ButtonSize.Small => "h-8 px-3 text-sm",
        ButtonSize.Medium => "h-10 px-4",
        ButtonSize.Large => "h-11 px-6",
        _ => ""
    };

    private string ComputedClass => $"{BaseStyles} {VariantStyles} {SizeStyles} {Class}";
}