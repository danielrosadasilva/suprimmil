{
  "name": "suprimmil",
  "version": "1.0.0",
  "scripts": {
    "build-css": "tailwindcss -i ./wwwroot/app.css -o ./wwwroot/output.css",
    "watch-css": "tailwindcss -i ./wwwroot/app.css -o ./wwwroot/output.css --watch",
    "watch-dotnet": "dotnet watch run",
    "dev": "concurrently \"npm run watch-css\" \"npm run watch-dotnet\" --kill-others"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0"
  }
}
