@using Microsoft.AspNetCore.Components.Authorization
@using suprimmil.Components.Pages

<CascadingAuthenticationState>
    <Router AppAssembly="typeof(Program).Assembly"            NotFoundPage="typeof(Pages.NotFound)">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(suprimmil.Components.Layout.MainLayout)">
                <NotAuthorized>
                    <LayoutView Layout="typeof(suprimmil.Components.Layout.UnauthenticatedLayout)">
                        <AuthorizeView Context="authContext">
                            <Authorized>
                                <RedirectToAccessDenied />
                            </Authorized>
                            <NotAuthorized>
                                <RedirectToLogin />
                            </NotAuthorized>
                        </AuthorizeView>
                    </LayoutView>
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
    </Router>
</CascadingAuthenticationState>