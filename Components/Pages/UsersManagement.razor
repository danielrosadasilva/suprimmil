@page "/users-management"

@using suprimmil.Dto.Access
@using suprimmil.Models
@using suprimmil.Components.Content
@using suprimmil.Services

@attribute [Authorize(Policy = "AdminOnly")]
@inject IUserService _userService;
@inject ToastService _toastService;

@rendermode InteractiveServer

@layout MainLayout

<PageTitle>Gestão de usuários</PageTitle>

<div class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-bold">Gestão de Usuários</h1>
    <button class="bg-blue-600 text-white px-4 py-2 rounded" @onclick="() => showModal = true">Adicionar usuário</button>
</div>

<UserModal IsOpen="@showModal" IsOpenChanged="@OnModalChanged" OnCreateUser="@OnCreateUser" />

<div class="overflow-x-auto bg-white rounded shadow">
    <table class="w-full text-left">
        <thead class="bg-slate-100">
            <tr>
                <th class="px-4 py-2">ID</th>
                <th class="px-4 py-2">Email</th>
                <th class="px-4 py-2">Usuário</th>
                <th class="px-4 py-2">Admin</th>
            </tr>
        </thead>
        <tbody>
            @if (users?.Count > 0)
            {
                @foreach (var u in users)
                {
                    <tr class="border-b hover:bg-slate-50">
                        <td class="px-4 py-2">@u.Id</td>
                        <td class="px-4 py-2">@u.Email</td>
                        <td class="px-4 py-2">@u.UserName</td>
                        <td class="px-4 py-2">@(u.IsAdmin ? "Sim" : "Não")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="px-4 py-6 text-center text-gray-500">Nenhum usuário encontrado.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<Toast />

@code {
    private bool showModal = false;
    private List<User> users = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        users = await _userService.GetAllUsersAsync();
    }

    private async Task OnCreateUser(CreateUserDto model)
    {
        var result = await _userService.CreateUserAsync(model.Email, model.Password, model.IsAdmin);

        if (result.Succeeded)
        {
            await _toastService.ShowToastAsync("Usuário criado com sucesso!", true);
            await LoadUsers();
        }
        else
        {
            var errors = string.Join(" ", result.Errors.Select(e => e.Description));
            await _toastService.ShowToastAsync("Falha ao criar usuário: " + errors, false);
        }
    }

    private async Task OnModalChanged(bool isOpen)
    {
        showModal = isOpen;
        await Task.CompletedTask;
    }
}
