@rendermode InteractiveServer
@namespace suprimmil.Components.Content

<div class="relative w-full h-[500px] overflow-hidden">

    <!-- SLIDER -->
    <div class="flex transition-transform duration-1000 ease-in-out h-full"
         style="transform: translateX(-@(currentIndex * 100)%);">

        @for (int i = 0; i < banners.Count; i++)
        {
            var banner = banners[i];

            <div class="relative w-full h-full flex-shrink-0">

                <!-- IMAGEM (crop automático) -->
                <img src="@banner" 
                     class="absolute inset-0 w-full h-full object-cover" 
                     alt="Banner @(i + 1)" />

                <!-- OVERLAY -->
                <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/40 to-transparent"></div>

                

            </div>
        }
    </div>
    <!-- CONTEÚDO -->
                <div class="absolute inset-0 flex items-center">
                    <div class="w-full px-4 sm:px-6 lg:px-10 xl:px-20 text-white">
                        
                        <div class="max-w-3xl">
                            
                            <h1 class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-bold leading-tight mb-4 text-white drop-shadow-lg">
                                SUPRIMMIL
                            </h1>

                            <p class="text-sm sm:text-base lg:text-lg xl:text-xl leading-relaxed mb-6 text-gray-100 line-clamp-3">
                                Soluções integradas em engenharia, suprimentos, montagem eletromecânica e manutenção industrial para resultados de alta performance.
                            </p>

                            <button class="border-2 border-white px-6 py-3 text-sm sm:text-base font-semibold 
                                         hover:bg-white hover:text-black transition duration-300 
                                         focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-black">
                                Detalhes
                            </button>

                        </div>
                    </div>
                </div>

    <!-- BOTÕES DE NAVEGAÇÃO -->
    <button @onclick="Prev"
            class="hidden absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-black/80 
                   text-white p-2 sm:p-3 rounded-full transition backdrop-blur-sm z-10">
        <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
    </button>

    <button @onclick="Next"
            class="hidden absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-black/80 
                   text-white p-2 sm:p-3 rounded-full transition backdrop-blur-sm z-10">
        <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
    </button>


</div>

@code {
    private int currentIndex = 0;

    private List<string> banners = new()
    {
        "images/banners/slider-01.jpg",
        "images/banners/slider-02.jpg",
        "images/banners/slider-03.jpg"
    };

    private System.Timers.Timer? sliderTimer;

    protected override void OnInitialized()
    {
        sliderTimer = new System.Timers.Timer(5000);
        sliderTimer.Elapsed += async (sender, e) => await InvokeAsync(Next);
        sliderTimer.Start();
    }

    private void Next()
    {
        currentIndex = (currentIndex + 1) % banners.Count;
        StateHasChanged();
    }

    private void Prev()
    {
        currentIndex = (currentIndex - 1 + banners.Count) % banners.Count;
        StateHasChanged();
    }

    private void GoToSlide(int index)
    {
        currentIndex = index;
        StateHasChanged();
    }

    public void Dispose()
    {
        sliderTimer?.Stop();
        sliderTimer?.Dispose();
    }
}