@namespace suprimmil.Components.Content

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 px-4 max-w-6xl mx-auto">
    @foreach (var item in items)
    {
        <div class="group flex flex-col rounded-xl shadow-lg bg-white overflow-hidden
                    transition-all duration-300 ease-out
                    hover:-translate-y-2 hover:shadow-2xl hover:shadow-orange-500/20
                    cursor-default border-2 border-orange-200 hover:border-orange-500">

            <!-- Top accent bar -->
            <div class="h-1.5 w-full bg-orange-500"></div>

            <div class="flex flex-col items-center justify-center p-8 bg-gradient-to-br from-orange-50 to-transparent">
                <div class="w-16 h-16 rounded-full bg-white shadow-md flex items-center justify-center
                            group-hover:scale-110 group-hover:shadow-lg group-hover:bg-orange-100 transition-all duration-300">
                    <i class="@item.IconClass text-2xl text-orange-600 group-hover:text-orange-700 transition-colors duration-300"></i>
                </div>
                <h2 class="mt-4 text-xl md:text-2xl font-extrabold text-orange-600 group-hover:text-orange-700 transition-colors duration-300">
                    @item.Title
                </h2>
            </div>

            <div class="flex-1 px-5 pb-2">
                <p class="text-center text-sm leading-relaxed text-gray-600">
                    @item.Description
                </p>
            </div>

            <div class="px-5 py-3 border-t border-orange-100">
                <a class="inline-flex items-center text-sm font-semibold text-orange-600
                          group-hover:text-orange-700 transition-colors duration-300"
                   href="@item.UrlButton" target="@item.Target">
                    @item.TitleButton
                    <i class="fa-solid fa-arrow-right ml-2 transform group-hover:translate-x-1 transition-transform duration-300 text-xs"></i>
                </a>
            </div>
        </div>
    }
</div>

@code {
    [Inject] IJSRuntime JSRuntime { get; set; } = default!;

    private List<CardItem> items = new()
    {
        new CardItem
        {
            Title = "Missão",
            Description = "Atender todas as expectativas e condicionantes dos negócios oriundos em fornecimentos de bens e serviços, com responsabilidade, idoneidade e ética empresarial.",
            IconClass = "fa-solid fa-compass",
            UrlButton = "#quemsomos",
            Target = "_self",
            TitleButton = "Saiba mais"
        },
        new CardItem
        {
            Title = "Visão",
            Description = "Ser a melhor empresa em atendimento a projetos e suprimentos de fornecimentos de materiais e equipamentos e serviços de montagem eletromecânica, manutencão industrial da região Norte.",
            IconClass = "fa-solid fa-eye",
            UrlButton = "#segmentos",
            Target = "_self",
            TitleButton = "Saiba mais"
        },
        new CardItem
        {
            Title = "Valores",
            Description = "Segurança zero acidentes, planejamento e sustentabilidade, qualidade e compromisso, ética e integridade, inovacão e melhoria continua dos processos, motivacão com liderança e evolucão.",
            IconClass = "fa-solid fa-gem",
            UrlButton = "#contato",
            Target = "_self",
            TitleButton = "Saiba mais"
        }
    };

    public class CardItem
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string IconClass { get; set; } = "";
        public string UrlButton { get; set; } = "";
        public string Target { get; set; } = "_self";
        public string TitleButton { get; set; } = "Saiba mais";
    }
}
