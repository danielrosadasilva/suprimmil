@namespace suprimmil.Components.Content

<div class="py-12 bg-gray-100">
    <div class="max-w-6xl mx-auto px-4">
        
        <h2 class="text-3xl font-bold text-center text-blue-900 mb-10">
            Segmentos em que atuamos:
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

            <!-- Card -->
            <div class="group flex items-start gap-4 bg-white p-6 rounded-lg shadow 
                transition-all duration-300 ease-out 
                hover:-translate-y-2 hover:shadow-xl hover:scale-[1.02]">

                <div class="w-12 h-12 flex flex-shrink-0 items-center justify-center rounded-full 
                    bg-orange-100 text-orange-600 transition 
                    group-hover:bg-orange-600 group-hover:text-white">

                    <!-- Engineering Icon -->
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M11 3v2m0 14v2m8-8h2M3 11H1m15.364-6.364l1.414 1.414M6.222 17.778l-1.414 1.414m12.728 0l-1.414-1.414M6.222 6.222L4.808 4.808" />
                    </svg>
                </div>

                <div>
                    <h3 class="font-semibold text-gray-800">Engenharia e Projetos</h3>
                    <p class="text-sm text-gray-600 mt-1">
                        Projetos personalizados para indústrias de diversos segmentos, abrangendo fabricação e montagem de equipamentos, caldeiraria, tubulação e estruturas metálicas.
                    </p>
                </div>
            </div>

            <!-- Suprimentos -->
            <div class="group flex items-start gap-4 bg-white p-6 rounded-lg shadow 
                transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:scale-[1.02]">

                <div class="w-12 h-12 flex flex-shrink-0 items-center justify-center rounded-full 
                    bg-orange-100 text-orange-600 group-hover:bg-orange-600 group-hover:text-white transition">

                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M3 7l9-4 9 4-9 4-9-4zM3 7v10l9 4 9-4V7" />
                    </svg>
                </div>

                <div>
                    <h3 class="font-semibold text-gray-800">Suprimentos</h3>
                    <p class="text-sm text-gray-600 mt-1">
                        Fornecimento de serviços de engenharia, projetos, equipamentos e componentes para caldeiraria, tubulação e estruturas metálicas.
                    </p>
                </div>
            </div>

            <!-- Construção -->
            <div class="group flex items-start gap-4 bg-white p-6 rounded-lg shadow 
                transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:scale-[1.02]">

                <div class="w-12 h-12 flex flex-shrink-0 items-center justify-center rounded-full 
                    bg-orange-100 text-orange-600 group-hover:bg-orange-600 group-hover:text-white transition">

                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10l9-7 9 7v11H3z" />
                    </svg>
                </div>

                <div>
                    <h3 class="font-semibold text-gray-800">Construção</h3>
                    <p class="text-sm text-gray-600 mt-1">
                        Montagem eletromecânica, manutenção industrial, overhall (paradas de alta complexidade)
                    </p>
                </div>
            </div>

            <!-- Fabricação -->
            <div class="group flex items-start gap-4 bg-white p-6 rounded-lg shadow 
                transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:scale-[1.02]">

                <div class="w-12 h-12 flex flex-shrink-0 items-center justify-center rounded-full 
                    bg-orange-100 text-orange-600 group-hover:bg-orange-600 group-hover:text-white transition">

                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M14.7 6.3a1 1 0 011.4 1.4l-8 8-4 1 1-4 8-8z" />
                    </svg>
                </div>

                <div>
                    <h3 class="font-semibold text-gray-800">Fabricação e Recuperação mecânica</h3>
                    <p class="text-sm text-gray-600 mt-1">
                        Peças conforme projetos, soldagem especializada (MIG/MAG e TIG) e tratamento térmico Jato e Pintura homologado;
                    </p>
                </div>
            </div>

            <!-- Usinagem -->
            <div class="group flex items-start gap-4 bg-white p-6 rounded-lg shadow 
                transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:scale-[1.02]">

                <div class="w-12 h-12 flex flex-shrink-0 items-center justify-center rounded-full 
                    bg-orange-100 text-orange-600 group-hover:bg-orange-600 group-hover:text-white transition">

                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor">
                        <circle cx="12" cy="12" r="3" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M19.4 15a7.97 7.97 0 000-6M4.6 9a7.97 7.97 0 000 6" />
                    </svg>
                </div>

                <div>
                    <h3 class="font-semibold text-gray-800">Usinagem de Peças</h3>
                    <p class="text-sm text-gray-600 mt-1">
                        Soluções completas em usinagem para diversas aplicações industriais, inclusive de campo;
                    </p>
                </div>
            </div>

            <!-- Materiais -->
            <div class="group flex items-start gap-4 bg-white p-6 rounded-lg shadow 
                transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:scale-[1.02]">

                <div class="w-12 h-12 flex flex-shrink-0 items-center justify-center rounded-full 
                    bg-orange-100 text-orange-600 group-hover:bg-orange-600 group-hover:text-white transition">

                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M20 13V7a2 2 0 00-2-2h-3V3H9v2H6a2 2 0 00-2 2v6" />
                    </svg>
                </div>

                <div>
                    <h3 class="font-semibold text-gray-800">Fornecimento de materiais metálicos</h3>
                    <p class="text-sm text-gray-600 mt-1">
                        Barras, buchas, perfis, polias, tubos, chapas, conexões, flanges, válvulas, metalon, nylon, latão, bronze, abrasivos em geral, ferramentas de corte e acabamento.
                    </p>
                </div>
            </div>

            <!-- Diferenciais -->
            <div class="group flex items-start gap-4 bg-white p-6 rounded-lg shadow 
                transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:scale-[1.02]
                md:col-span-2 lg:col-span-3">

                <div class="w-12 h-12 flex flex-shrink-0 items-center justify-center rounded-full 
                    bg-orange-100 text-orange-600 group-hover:bg-orange-600 group-hover:text-white transition">

                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                </div>

                <div>
                    <h3 class="font-semibold text-gray-800">Diferenciais</h3>
                    <p class="text-sm text-gray-600 mt-1">
                        Localização estratégica em Barcarena e Ananindeua PA, infraestrutura moderna e equipe especializada.
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>