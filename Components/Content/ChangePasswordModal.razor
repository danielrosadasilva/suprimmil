@using suprimmil.Dto.Access
@namespace suprimmil.Components.Content

@if (IsOpen)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/40" @onclick="@(_ => CloseModal())">
        <div class="bg-white rounded-lg shadow-lg w-full max-w-md p-5" @onclick:stopPropagation="true">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-xl font-semibold">Alterar Senha</h2>
                <button type="button" class="text-gray-600 hover:text-gray-900" @onclick="CloseModal">&#x2715;</button>
            </div>

            <EditForm Model="model" OnValidSubmit="OnSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="block font-medium mb-1">Senha Atual</label>
                    <InputText class="w-full border rounded px-3 py-2" type="password" placeholder="Digite sua senha atual" @bind-Value="model.CurrentPassword" />
                </div>
                <div class="mb-3">
                    <label class="block font-medium mb-1">Nova Senha</label>
                    <InputText class="w-full border rounded px-3 py-2" type="password" placeholder="Digite a nova senha" @bind-Value="model.NewPassword" />
                </div>
                <div class="mb-4">
                    <label class="block font-medium mb-1">Confirmar Nova Senha</label>
                    <InputText class="w-full border rounded px-3 py-2" type="password" placeholder="Confirme a nova senha" @bind-Value="model.ConfirmPassword" />
                </div>

                <div class="flex justify-end gap-2">
                    <button type="button" class="px-4 py-2 bg-gray-200 rounded" @onclick="CloseModal">Cancelar</button>
                    <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded">Alterar</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private ChangePasswordDto model = new();

    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public EventCallback<ChangePasswordDto> OnSave { get; set; }

    private async Task OnSubmit()
    {
        await OnSave.InvokeAsync(model);
        model = new ChangePasswordDto();
    }

    private async Task CloseModal()
    {
        IsOpen = false;
        model = new ChangePasswordDto();
        await IsOpenChanged.InvokeAsync(false);
    }
}
